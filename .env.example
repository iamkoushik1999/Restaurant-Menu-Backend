NODE_ENV=development

PORT=5050

# MongoDB Atlas connection string
MONGODB_URL=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/Restaurant-Menu

# Generate a long random string for production, e.g: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-secret
JWT_ACCESS_EXPIRES=15d
JWT_REFRESH_EXPIRES=365d

# Comma-separated list of allowed frontend origins (no trailing slash)
FRONTEND_URL=http://localhost:5173

# Cloudinary (image uploads) - https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
